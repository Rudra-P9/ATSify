rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Reusable helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Entity Validations
    function isValidUser(data) {
      return data.uid == request.auth.uid
        && data.email is string
        && data.email.size() > 0
        && data.email.size() <= 256;
    }

    function isValidScan(data) {
      return data.userId == request.auth.uid
        && data.resumeText is string
        && data.resumeText.size() > 0
        && data.resumeText.size() <= 50000
        && data.results is list
        && data.results.size() == 6
        && data.createdAt == request.time;
    }

    // 3. Collection Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    match /scans/{scanId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidScan(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
